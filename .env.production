# 前端环境变量配置

# API 地址 - 生产环境
NEXT_PUBLIC_API_URL=https://shanhai-production.up.railway.app/api

# ========== 第三方登录配置 ==========
# Google 登录
# 在 https://console.cloud.google.com/ 创建 OAuth 客户端
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Facebook 登录
# 在 https://developers.facebook.com/ 创建应用
# EXPO_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id
