# 前端环境变量配置

# API 地址
# 开发环境
NEXT_PUBLIC_API_URL=http://localhost:3000/api
# 生产环境 (Railway)
# NEXT_PUBLIC_API_URL=https://your-railway-app.up.railway.app/api

# ========== 第三方登录配置 ==========
# Google 登录 - 在 .env.local 中配置，不要提交到版本控制
# 1. 前往 https://console.cloud.google.com/
# 2. 创建 OAuth 客户端 ID
# 3. 添加Authorized JavaScript origins:
#    - http://localhost:8081 (Expo开发)
#    - https://your-app.expo.app (Expo生产)
# 4. 添加Authorized redirect URIs:
#    - https://auth.expo.io/@your-username/shanhai-app
#    - shanhai://oauth/google (自定义scheme)
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Facebook 登录
# 1. 前往 https://developers.facebook.com/
# 2. 创建应用并添加 Facebook 登录
# 3. 设置有效的 OAuth 重定向 URI
# EXPO_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id
